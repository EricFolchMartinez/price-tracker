# Production environment for the Price Tracker public demo.
# Copy to .env.prod on the Raspberry Pi (never commit .env.prod).

# Hides /docs, /redoc and /openapi.json on the FastAPI service.
ENVIRONMENT=production

# Public demo = static, read-only data. Keep the scraper OFF.
RUN_DASHBOARD=true
RUN_API=true
RUN_SCHEDULER=false
DEMO_MODE=true

TZ=Europe/Madrid

# Own SQLite database, persisted in the ./data volume (absolute path inside the container).
DATABASE_URL=sqlite:////app/data/prices.sqlite

# Sidebar links shown in the dashboard.
PORTFOLIO_URL=https://ericfolch.com
GITHUB_URL=https://github.com/EricFolchMartinez
LINKEDIN_URL=https://www.linkedin.com/in/eric-folch/
